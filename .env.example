# Configuration Supabase pour le classement en ligne.
# Copie ce fichier en `.env` et renseigne tes valeurs (dashboard Supabase > Project Settings > API).
# Sans ces variables, le jeu reste jouable mais le classement est masqué.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Serveur multijoueur (voir server/README.md).
# En local : ws://localhost:8787  (valeur par défaut si non renseigné).
# En production (site servi en HTTPS) : wss://<ton-app>.onrender.com
# Sans serveur joignable, seul le mode solo est jouable.
VITE_SERVER_URL=
